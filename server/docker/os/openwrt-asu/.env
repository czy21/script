REDIS_URL=redis://:{{ param_db_redis_password }}@{{ param_db_redis_host }}:{{ param_db_redis_port }}
PUBLIC_PATH={{ param_docker_data }}/{{ param_role_name }}/data
CONFIG_PATH={{ param_docker_data }}/{{ param_role_name }}/conf
BASE_CONTAINER=docker.io/openwrt/imagebuilder
REPOSITORY_ALLOW_LIST=["https://mirrors.ustc.edu.cn/openwrt/","https://openwrt-download.czy21.com"]
ALLOW_DEFAULTS=1
LOG_LEVEL=INFO
CONTAINER_SOCKET_PATH=/run/user/1000/podman/podman.sock
BUILD_FAILURE_TTL=1m
JOB_TIMEOUT=1h